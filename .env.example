# ─── ARIA Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# ── Required: at least one AI provider ──
OPENROUTER_API_KEY=        # https://openrouter.ai/keys
GROQ_API_KEY=              # https://console.groq.com/keys

# ── Optional: additional AI providers ──
CLOUDFLARE_ACCOUNT_ID=     # Cloudflare dashboard → Workers & Pages
CLOUDFLARE_AI_API=         # Cloudflare AI API token
DEEPSEEK_KEY=              # https://platform.deepseek.com
NEMOTRON_NVIDIA=           # https://integrate.api.nvidia.com
OPENAI_KEY=                # https://platform.openai.com (for DALL-E)

# ── Optional: local model servers ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
LMSTUDIO_URL=http://localhost:1234
LMSTUDIO_MODEL=

# ── Optional: tools ──
NEWSDATA_KEY=              # https://newsdata.io
SERPAPI_KEY=               # https://serpapi.com (better web search)

# ── Optional: Google Calendar integration ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Optional: TTS ──
CUSTOM_VOICE=              # ElevenLabs voice ID or similar

# ── Server ──
PORT=3000
RENDER_EXTERNAL_URL=       # Set automatically on Render
