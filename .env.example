# ─── ARIA Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# ── Required: at least one AI provider ──
OPENROUTER_API_KEY=        # https://openrouter.ai/keys
GROQ_API_KEY=              # https://console.groq.com/keys

# ── Optional: additional AI providers ──
CLOUDFLARE_ACCOUNT_ID=     # Cloudflare dashboard → Workers & Pages
CLOUDFLARE_AI_API=         # Cloudflare AI API token
DEEPSEEK_KEY=              # https://platform.deepseek.com
NEMOTRON_NVIDIA=           # https://integrate.api.nvidia.com
OPENAI_KEY=                # https://platform.openai.com (for DALL-E)

# ── Optional: local model servers ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
LMSTUDIO_URL=http://localhost:1234
LMSTUDIO_MODEL=

# ── Optional: tools ──
NEWSDATA_KEY=              # https://newsdata.io
SERPAPI_KEY=               # https://serpapi.com (better web search)

# ── Optional: Google Calendar integration ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Optional: TTS ──
CUSTOM_VOICE=              # ElevenLabs voice ID or similar

# ── Cloud persistence (Firestore) ────────────────────────────────
# Render's filesystem is EPHEMERAL — without this, data/ (memory, tasks,
# behaviour, chats) is wiped on every redeploy. Set this to the personal-suite
# service-account JSON (raw JSON on one line, or base64) to persist state to
# Firestore (collection: aria_state). Leave empty to run local-only.
# Firebase console > Project settings > Service accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT=
# NOTE: data/rag/vectors.json is intentionally NOT synced (too big for a
# Firestore doc; embeddings are nested arrays). RAG re-ingests as a cache.

# ── Cross-app context: GRIND + hardware-tracker (Firestore) ──────
# Set this to your canonical personal-suite Firebase UID (see MIGRATION.md §3
# — the GRIND UID) to let ARIA read your GRIND streak/skills and
# hardware-tracker inventory for context (see lib/life-context.js). Requires
# FIREBASE_SERVICE_ACCOUNT above. Leave empty to skip — chat works the same,
# just without that context block.
ARIA_OWNER_UID=

# ── Server ──
PORT=3000
RENDER_EXTERNAL_URL=       # Set automatically on Render

# ── Daily briefing ──────────────────────────────────────────────
BRIEFING_ENABLED=false     # Set to true to enable daily briefings
BRIEFING_HOUR=8            # Hour (0-23) to deliver briefing (server time)
